{
  "name": "ffmpeg-expo",
  "version": "0.0.1",
  "description": "FFmpeg for Expo/React Native - native video/audio processing without ffmpeg-kit",
  "type": "commonjs",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:plugin": "tsc -p plugin/tsconfig.json",
    "prepare:package": "npm run build && npm run build:plugin",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf build plugin/build",
    "pack:check": "npm run prepare:package && node ../../scripts/validate-package.js && publint .",
    "prepublishOnly": "npm run prepare:package",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "expo",
    "react-native",
    "ffmpeg",
    "video",
    "audio",
    "transcoding",
    "compression"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kingjnr4/ffmpeg-expo.git"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "expo": ">=49.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "expo": "^52.0.0",
    "expo-module-scripts": "^3.5.0",
    "expo-modules-core": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "build",
    "android",
    "!android/jniLibs",
    "!android/jniLibs/**",
    "!android/libs",
    "!android/libs/**",
    "ios",
    "!ios/Frameworks",
    "!ios/Frameworks/**",
    "plugin/build",
    "scripts",
    "expo-module.config.json",
    "app.plugin.js"
  ],
  "ffmpegExpo": {
    "binaryReleaseTag": "ffmpeg-6.1.1-r1"
  }
}
