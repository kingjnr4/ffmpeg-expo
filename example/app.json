{
  "expo": {
    "name": "expo-ffmpeg-example",
    "slug": "expo-ffmpeg-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "expo-ffmpeg-example",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.expoffmpeg"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.example.expoffmpeg"
    },
    "plugins": [
      "expo-router",
      [
        "ffmpeg-expo",
        {
          "includeX86": true
        }
      ]
    ]
  }
}
