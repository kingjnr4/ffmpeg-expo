{
  "name": "expo-ffmpeg-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "changesets:add": "changeset",
    "changesets:version": "changeset version",
    "changesets:publish": "pnpm run pack:check && changeset publish",
    "pack:check": "pnpm --filter ffmpeg-expo run pack:check",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "pkg-pr-new": "^0.0.75",
    "publint": "^0.3.12",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22.13.0"
  }
}
